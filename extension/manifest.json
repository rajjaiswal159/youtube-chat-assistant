{
  "manifest_version": 3,
  "name": "YouTube Chat",
  "version": "1.0",

  "permissions": [
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "Open Side Panel"
  }
}